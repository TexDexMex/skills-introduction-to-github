# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# ---------------------------------------------------------------------------

# --- Supabase (Project Settings -> API) ---
# Safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SERVER-ONLY. Full admin access — bypasses Row-Level Security.
# Used only in server code (cron, recipient portal, signed downloads).
# Never prefix with NEXT_PUBLIC_ and never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Private Storage bucket that holds the credential files.
SUPABASE_STORAGE_BUCKET=credentials

# --- Email (Resend -> API Keys) ---
RESEND_API_KEY=re_xxxxxxxx
# The "from" address must be on a domain you've verified in Resend.
EMAIL_FROM="Chiron Anesthesia Credentials <credentials@chironanesthesia.health>"
# Where expiration reminders are sent (the owner's inbox).
REMINDER_TO_EMAIL=steven@chironanesthesia.com

# --- App ---
# Public base URL, used to build recipient portal links in emails.
NEXT_PUBLIC_APP_URL=https://chironanesthesia.health

# Shared secret that authorizes the Vercel Cron call to the reminder endpoint.
# Generate with:  openssl rand -hex 32
CRON_SECRET=generate-a-long-random-string
